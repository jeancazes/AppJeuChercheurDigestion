# Configuration Supabase
# ======================================
# Pour obtenir ces valeurs :
# 1. Allez sur https://supabase.com
# 2. Sélectionnez votre projet
# 3. Cliquez sur "Project Settings" (icône engrenage)
# 4. Allez dans "API"
# 5. Copiez "Project URL" et "anon public" key

NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_clé_publique_anon_ici

# ⚠️ IMPORTANT : 
# - Renommez ce fichier en ".env.local"
# - Ne commitez JAMAIS .env.local sur Git
# - Sur Vercel, ajoutez ces variables dans les "Environment Variables"
